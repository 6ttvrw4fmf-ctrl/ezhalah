# These are read by the Python scrapers (python-dotenv loads them at startup).

# The Supabase project (same one the app uses). Project ref: aannarbkwcymrotzwdbo
SUPABASE_URL=https://aannarbkwcymrotzwdbo.supabase.co

# The SERVICE ROLE key — bypasses RLS, lets the scraper UPSERT into `listings`.
